<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
body {
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-family: Arial, sans-serif;
  color: white;
  flex-direction: column;
}
.animation {
  text-align: center;
}
.circle {
  width: 80px;
  height: 80px;
  border: 4px solid #333;
  border-top: 4px solid white;
  border-radius: 50%;
  margin: 20px auto;
  animation: spin 1s linear infinite;
}
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
.text {
  font-size: 18px;
  animation: fade 2s ease-in-out infinite;
}
@keyframes fade {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
</style>
</head>
<body>
<div class="animation" id="shutdownArea">
  <div class="circle"></div>
  <div class="text">Shutting down...</div>
</div>
<script>
// Harmless visual effect - no system commands executed
setTimeout(() => {
  document.getElementById('shutdownArea').innerHTML = 
    '<div style="opacity:0;transition:opacity 3s;" id="fadeOut"><div class="text" style="font-size:14px;color:#555;">Goodbye</div></div>';
  setTimeout(() => {
    document.getElementById('shutdownArea').innerHTML = 
      '<div class="text" style="font-size:12px;color:#333;">Tap to restart</div>';
    document.body.onclick = () => location.reload();
  }, 3000);
}, 4000);
</script>
</body>
</html>
